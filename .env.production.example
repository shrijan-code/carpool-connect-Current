# ================================================
# PRODUCTION ENVIRONMENT (.env.production)
# ================================================
# ⚠️  CAUTION: This file contains LIVE/PRODUCTION credentials
# ⚠️  NEVER commit this file to version control
# ⚠️  Only use these values when building for store submission

# Environment Identifier
APP_ENV=production

# Firebase Configuration (PRODUCTION PROJECT)
# Get these from: Firebase Console > Project Settings > Your apps > Config
# This should be a SEPARATE Firebase project from development!
FIREBASE_API_KEY=your_prod_firebase_api_key
FIREBASE_AUTH_DOMAIN=your-prod-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-prod-project-id
FIREBASE_STORAGE_BUCKET=your-prod-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_prod_messaging_sender_id
FIREBASE_APP_ID=your_prod_app_id
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Stripe Configuration (LIVE MODE)
# ⚠️  These are LIVE keys - real money will be processed!
# Get these from: Stripe Dashboard > Developers > API Keys (toggle to LIVE mode)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_live_key_here
STRIPE_SECRET_KEY=sk_live_your_live_secret_key

# Google Maps & Places API
# Same API key can be shared across environments
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=your_google_places_api_key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Google OAuth Client IDs (for Google Sign-In on mobile)
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=your_ios_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=your_android_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=your_web_client_id.apps.googleusercontent.com

# Production Settings
DEV_MODE=false
API_TIMEOUT=30000
