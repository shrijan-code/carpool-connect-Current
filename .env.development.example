# ================================================
# DEVELOPMENT ENVIRONMENT (.env.development)
# ================================================
# Copy this file to .env.development and fill in your DEV Firebase values
# This uses your DEVELOPMENT Firebase project for safe testing

# Environment Identifier
APP_ENV=development

# Firebase Configuration (DEVELOPMENT PROJECT)
# Get these from: Firebase Console > Project Settings > Your apps > Config
FIREBASE_API_KEY=your_dev_firebase_api_key
FIREBASE_AUTH_DOMAIN=your-dev-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-dev-project-id
FIREBASE_STORAGE_BUCKET=your-dev-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_dev_messaging_sender_id
FIREBASE_APP_ID=your_dev_app_id
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Stripe Configuration (TEST MODE)
# Get these from: Stripe Dashboard > Developers > API Keys (TEST mode)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key_here
STRIPE_SECRET_KEY=sk_test_your_test_secret_key

# Google Maps & Places API
# Same API key can be shared across environments (billed separately)
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=your_google_places_api_key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Google OAuth Client IDs (for Google Sign-In on mobile)
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=your_ios_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=your_android_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=your_web_client_id.apps.googleusercontent.com

# Development Settings
DEV_MODE=true
API_TIMEOUT=15000
