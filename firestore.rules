rules_version = '2';
service cloud.firestore {
  match /databases/{db}/documents {

    // ============================================================================
    // SIMPLIFIED SECURITY RULES - Focus on Auth & Ownership
    // Removes strict field validation to prevent "permission denied" errors
    // ============================================================================

    // Security helper functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isAdmin() { return isSignedIn() && request.auth.token.admin == true; }
    function isRecentRequest() {
      return request.time > timestamp.date(2024, 1, 1) && 
             request.time < timestamp.date(2030, 12, 31);
    }

    // ============================================================================
    // USERS - Simplified
    // ============================================================================
    match /users/{uid} {
      // Any signed-in user can read user profiles
      allow read: if isSignedIn() && isRecentRequest();
      
      // Users can only create their own profile
      allow create: if isSignedIn() && 
                      request.auth.uid == uid &&
                      isRecentRequest();
      
      // Users can only update their own profile
      allow update: if isOwner(uid) && isRecentRequest();
      
      // Prevent deletion of user profiles
      allow delete: if false;
    }

    // ============================================================================
    // RIDES - With Security Protections
    // ============================================================================
    
    // Helper: Check if critical fields are being modified
    function isModifyingCriticalFields() {
      return request.resource.data.pricePerSeat != resource.data.pricePerSeat ||
             request.resource.data.seatsTotal != resource.data.seatsTotal;
    }
    
    // Helper: Check if ride has active bookings (for status/seats updates only)
    // Note: We can't query bookings from rules, so we rely on Cloud Functions
    // for booking-related validation. This rule prevents direct price manipulation.
    function isOnlyStatusUpdate() {
      return request.resource.data.pricePerSeat == resource.data.pricePerSeat &&
             request.resource.data.seatsTotal == resource.data.seatsTotal &&
             request.resource.data.departureTime == resource.data.departureTime &&
             request.resource.data.origin == resource.data.origin &&
             request.resource.data.destination == resource.data.destination;
    }
    
    match /rides/{rideId} {
      // Signed-in users can read rides (for browsing available rides)
      allow read: if isSignedIn() && isRecentRequest();
      
      // Drivers can create rides (they must set themselves as driver)
      allow create: if isSignedIn() && 
                      isRecentRequest() &&
                      request.resource.data.driverId == request.auth.uid;
      
      // Drivers can update their own rides with restrictions:
      // - Cannot modify price/seats directly if ride is active/started
      // - Critical field changes must go through Cloud Functions
      allow update: if isSignedIn() && 
                      isRecentRequest() &&
                      resource.data.driverId == request.auth.uid &&
                      (
                        // Allow any update if ride is upcoming AND not modifying critical fields
                        (resource.data.status == 'upcoming' && !isModifyingCriticalFields()) ||
                        // OR it's only a status/tracking update (no price/seats change)
                        isOnlyStatusUpdate()
                      );
      
      // Drivers can delete their own upcoming/cancelled rides
      allow delete: if isSignedIn() && 
                      isRecentRequest() &&
                      resource.data.driverId == request.auth.uid &&
                      (resource.data.status == 'upcoming' || resource.data.status == 'cancelled');
    }

    // ============================================================================
    // BOOKINGS - Simplified with flexible permissions
    // ============================================================================
    
    // Helper: Check if the update only modifies review-related fields
    function isReviewFieldsOnlyUpdate() {
      let allowedFields = ['driverReviewedRider', 'riderReviewedDriver', 
                           'driverReviewId', 'riderReviewId', 'updatedAt'];
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return changedKeys.hasOnly(allowedFields);
    }
    
    match /bookings/{bookingId} {
      // Allow read only if user is involved in the booking (rider or driver)
      // This prevents unauthorized users from viewing other users' booking details
      // Also allow read if user is the driver of the ride (for getting ride participants in chat)
      allow read: if isSignedIn() && isRecentRequest() &&
                    (
                      resource.data.riderId == request.auth.uid ||
                      resource.data.passengerId == request.auth.uid ||
                      resource.data.driverId == request.auth.uid ||
                      // Allow driver to query bookings for their rides (for chat participants)
                      resource.data.ride.driverId == request.auth.uid
                    );
      
      // Riders can create bookings
      allow create: if isSignedIn() &&
                      isRecentRequest() &&
                      (
                        request.resource.data.riderId == request.auth.uid ||
                        request.resource.data.passengerId == request.auth.uid
                      );

      // Both rider and driver can update bookings they're involved in
      // OR if it's a review-only update and user is a participant
      allow update: if isSignedIn() &&
                      isRecentRequest() &&
                      (
                        resource.data.riderId == request.auth.uid ||
                        resource.data.passengerId == request.auth.uid ||
                        resource.data.driverId == request.auth.uid ||
                        isAdmin() ||
                        // Allow review field updates for any authenticated user
                        // (the review creation rules already validate the reviewer)
                        isReviewFieldsOnlyUpdate()
                      );
      
      // Prevent deletion (use status updates instead)
      allow delete: if false;
    }

    // ============================================================================
    // REVIEWS - Two-way review system for drivers and riders
    // ============================================================================
    match /reviews/{reviewId} {
      // Users can read reviews they wrote or received
      allow read: if isSignedIn() && isRecentRequest() &&
                    (resource.data.reviewerId == request.auth.uid ||
                     resource.data.revieweeId == request.auth.uid);
      
      // Users can create reviews as the reviewer with valid rating
      allow create: if isSignedIn() && isRecentRequest() &&
                      request.resource.data.reviewerId == request.auth.uid &&
                      request.resource.data.rating >= 1 &&
                      request.resource.data.rating <= 5 &&
                      request.resource.data.reviewerRole in ['driver', 'rider'] &&
                      request.resource.data.revieweeRole in ['driver', 'rider'];
      
      // No updates or deletes to reviews (immutable once created)
      allow update, delete: if false;
    }

    // ============================================================================
    // STRIPE EVENTS - Webhook deduplication (system-only writes)
    // ============================================================================
    match /stripe_events/{eventId} {
      // No client reads/writes - system only via Cloud Functions
      allow read, write: if false;
    }

    // ============================================================================
    // AUDIT EVENTS - Activity trail for disputes
    // ============================================================================
    match /audit_events/{eventId} {
      // Admins can read all, users can read own events
      allow read: if isSignedIn() && isRecentRequest() &&
                    (isAdmin() || 
                     resource.data.actorId == request.auth.uid ||
                     resource.data.resourceId == request.auth.uid);
      
    }

    // ============================================================================
    // RATE LIMITS - Anti-abuse rate limiting
    // ============================================================================
    match /rate_limits/{userId} {
      // Users can only read their own rate limit data
      allow read: if isSignedIn() && request.auth.uid == userId;
      
      // Only Cloud Functions can write (via admin SDK)
      allow write: if false;
    }

    // ============================================================================
    // TRIP SHARE TOKENS - Live trip sharing links
    // ============================================================================
    match /trip_share_tokens/{tokenId} {
      // Anyone can read tokens (for shared links)
      allow read: if isRecentRequest();
      
      // Only token creator can write
      allow create: if isSignedIn() && isRecentRequest() &&
                      request.resource.data.riderId == request.auth.uid;
      
      // Creator can update location
      allow update: if isSignedIn() && isRecentRequest() &&
                      resource.data.riderId == request.auth.uid;
      
      // Creator can delete
      allow delete: if isSignedIn() && 
                      resource.data.riderId == request.auth.uid;
    }

    // ============================================================================
    // MESSAGES - Chat functionality with stricter access control
    // ============================================================================
    match /messages/{messageId} {
      // Helper: Check if user is a participant in the message thread
      // Users can read messages where they are the sender, or the message
      // is part of a ride/booking they're involved in
      allow read: if isSignedIn() && isRecentRequest() &&
                    (
                      // Direct participant check (denormalized)
                      (resource.data.participants != null && 
                       request.auth.uid in resource.data.participants) ||
                      // User is the sender
                      resource.data.senderId == request.auth.uid ||
                      // Fallback for thread participants
                      (resource.data.threadId != null && 
                       get(/databases/$(database)/documents/message_threads/$(resource.data.threadId)).data.participants != null &&
                       request.auth.uid in get(/databases/$(database)/documents/message_threads/$(resource.data.threadId)).data.participants)
                    );
      
      // Users can create messages as themselves
      allow create: if isSignedIn() && isRecentRequest() &&
                      request.resource.data.senderId == request.auth.uid;
      
      // Only the sender can update their messages, or participants can mark as read
      allow update: if isSignedIn() && isRecentRequest() &&
                      (
                        resource.data.senderId == request.auth.uid ||
                        // Allow marking as read by participants
                        (resource.data.participants != null && 
                         request.auth.uid in resource.data.participants)
                      );
      allow delete: if false;
    }

    // Message threads for organizing conversations - participant access only
    // Query patterns supported:
    // - Query by bookingId: Works because rules check driverId/passengerId
    // - Query by participants array-contains: Works directly
    match /message_threads/{threadId} {
      // Allow read if user is a participant (via array or explicit fields)
      allow read: if isSignedIn() && isRecentRequest() &&
                    (
                      // User is in participants array
                      (resource.data.participants != null && 
                       request.auth.uid in resource.data.participants) ||
                      // User is the driver of this thread
                      resource.data.driverId == request.auth.uid ||
                      // User is the passenger of this thread
                      resource.data.passengerId == request.auth.uid
                    );
      // Allow create if user will be a participant (either in array or as driver/passenger)
      allow create: if isSignedIn() && isRecentRequest() &&
                      (
                        // User is in participants array
                        (request.resource.data.participants != null &&
                         request.auth.uid in request.resource.data.participants) ||
                        // User is the driver
                        request.resource.data.driverId == request.auth.uid ||
                        // User is the passenger
                        request.resource.data.passengerId == request.auth.uid
                      );
      allow update: if isSignedIn() && isRecentRequest() &&
                      (
                        // User is in participants array
                        (resource.data.participants != null &&
                         request.auth.uid in resource.data.participants) ||
                        // User is the driver
                        resource.data.driverId == request.auth.uid ||
                        // User is the passenger
                        resource.data.passengerId == request.auth.uid
                      );
      allow delete: if false;
    }

    // Delivery messages - participant access only
    match /delivery_messages/{messageId} {
      allow read: if isSignedIn() && isRecentRequest() &&
                    (
                      resource.data.senderId == request.auth.uid ||
                      resource.data.businessId == request.auth.uid ||
                      resource.data.driverId == request.auth.uid
                    );
      allow create: if isSignedIn() && isRecentRequest() &&
                      request.resource.data.senderId == request.auth.uid;
      allow update: if isSignedIn() && isRecentRequest() &&
                      (
                        resource.data.senderId == request.auth.uid ||
                        resource.data.businessId == request.auth.uid ||
                        resource.data.driverId == request.auth.uid
                      );
      allow delete: if false;
    }

    // ============================================================================
    // SAFETY REPORTS
    // ============================================================================
    match /safety_reports/{reportId} {
      allow read: if isSignedIn() && 
                    isRecentRequest() &&
                    (resource.data.reporterId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && 
                      isRecentRequest() &&
                      request.resource.data.reporterId == request.auth.uid;
      // Allow reporter to update their own report (for adding evidence photos)
      // Allow admins to update for status changes
      allow update: if isSignedIn() && 
                      isRecentRequest() &&
                      (resource.data.reporterId == request.auth.uid || isAdmin());
      allow delete: if false;
    }

    // ============================================================================
    // EMERGENCY CONTACTS
    // ============================================================================
    match /emergency_contacts/{contactId} {
      allow read: if isSignedIn() && 
                    isRecentRequest() &&
                    resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && 
                      isRecentRequest() &&
                      request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && 
                      isRecentRequest() &&
                      resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && 
                      isRecentRequest() &&
                      resource.data.userId == request.auth.uid;
    }

    // User Emergency Contacts Subcollection (Legacy)
    match /users/{userId}/emergencyContacts/{contactId} {
      allow read, write: if isSignedIn() && 
                           isRecentRequest() &&
                           userId == request.auth.uid;
    }

    // ============================================================================
    // DELIVERIES - Simplified
    // ============================================================================
    match /deliveries/{deliveryId} {
      allow read: if isSignedIn() && isRecentRequest();
      
      allow create: if isSignedIn() &&
                      isRecentRequest() &&
                      request.resource.data.businessId == request.auth.uid;
      
      allow update: if isSignedIn() && isRecentRequest() &&
                      (
                        resource.data.businessId == request.auth.uid ||
                        resource.data.driverId == request.auth.uid ||
                        // Allow claiming a pending delivery
                        resource.data.status == 'pending'
                      );
      
      allow delete: if isSignedIn() && 
                      isRecentRequest() &&
                      resource.data.businessId == request.auth.uid;
    }

    // Delivery Bookings
    match /delivery_bookings/{bookingId} {
      allow read: if isSignedIn() && isRecentRequest();
      allow create: if isSignedIn() && isRecentRequest();
      allow update: if isSignedIn() && isRecentRequest();
      allow delete: if false;
    }
    
    // ============================================================================
    // SYSTEM COLLECTIONS
    // ============================================================================
    
    // Security audit logs - only Cloud Functions can write
    match /security_logs/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    // Rate limiting data
    match /rate_limits/{limitId} {
      allow read, write: if isAdmin();
    }
    
    // System health monitoring
    match /system_health/{healthId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    // Audit logs - authenticated users can create
    match /audit_logs/{logId} {
      allow create: if isSignedIn();
      allow read, delete: if isAdmin();
      allow update: if false;
    }
    
    // ============================================================================
    // NOTIFICATIONS - Simplified
    // ============================================================================
    match /notifications/{notificationId} {
      // Users can read their own notifications
      allow read: if isSignedIn() && 
                    isRecentRequest() &&
                    resource.data.userId == request.auth.uid;
      
      // Any signed-in user can create notifications
      allow create: if isSignedIn() && isRecentRequest();
      
      // Users can update their own notifications (mark as read)
      allow update: if isSignedIn() && 
                      isRecentRequest() &&
                      resource.data.userId == request.auth.uid;
      
      // Users can delete their own notifications
      allow delete: if isSignedIn() && 
                      isRecentRequest() &&
                      resource.data.userId == request.auth.uid;
    }
    
    // ============================================================================
    // WEBHOOK EVENT DEDUPLICATION - Cloud Functions Only
    // ============================================================================
    match /processed_webhook_events/{eventId} {
      // No client access - only Cloud Functions can read/write
      allow read, write: if false;
    }
    
    // Default deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}