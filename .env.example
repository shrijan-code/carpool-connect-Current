# Firebase Configuration
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id

# Stripe Configuration
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Google Maps & Places API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Environment
ENVIRONMENT=development

# API URLs
FIREBASE_FUNCTIONS_URL=https://your-region-your-project-id.cloudfunctions.net

# Safety & Emergency Configuration
SAFETY_EMAIL_RECIPIENT=safety@yourapp.com

# Development Settings
DEV_MODE=true
API_TIMEOUT=15000

# App Configuration
APP_SCHEME=carpoolconnect
APP_VERSION=1.0.0