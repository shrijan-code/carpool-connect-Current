rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper function to check if user is admin
    // Note: Storage rules cannot directly query Firestore, so admin check relies on custom claims
    // Admins should have "admin" custom claim set via Firebase Admin SDK
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }
    
    // Profile pictures - PUBLIC for all authenticated users (can see other users' profiles)
    match /profile-pictures/{userId}/{allPaths=**} {
      allow read: if request.auth != null; // All authenticated users can view profile pics
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Vehicle documents (registration, insurance) - PRIVATE: only owner + admins
    // These are sensitive documents that need admin review
    match /vehicle-documents/{userId}/{allPaths=**} {
      allow read: if request.auth != null && 
        (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Safety report evidence - PRIVATE: only uploader + admins
    // Contains sensitive incident photos that should not be publicly accessible
    match /safety-reports/{reportId}/{allPaths=**} {
      allow read: if request.auth != null && 
        (resource.metadata.uploadedBy == request.auth.uid || isAdmin());
      allow write: if request.auth != null && 
        (resource == null || resource.metadata.uploadedBy == request.auth.uid);
    }
    
    // Incident images - PRIVATE: only uploader + admins
    match /incident-images/{userId}_{allPaths=**} {
      allow read: if request.auth != null && 
        (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Chat images - authenticated users can access
    // Note: Full participant verification would require Firestore lookup which isn't possible in Storage rules
    // The chatId includes participant UIDs for basic validation
    match /chat-images/{chatId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        (chatId.matches('.*' + request.auth.uid + '.*') || resource == null);
    }
    
    // Delivery images - authenticated users involved in delivery
    // deliveryId format should include relevant user IDs for validation
    match /delivery-images/{deliveryId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        (resource == null || resource.metadata.uploadedBy == request.auth.uid);
    }
    
    // Test connection path
    match /test-connection.txt {
      allow read: if true;
    }
    
    // Storage test for connectivity
    match /storage-test/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Default deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}